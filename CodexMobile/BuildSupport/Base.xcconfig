// Shared public defaults for open-source builds.
// Real private endpoints belong in the ignored PrivateOverrides.xcconfig file.

REMODEX_DEVELOPMENT_TEAM =
REMODEX_APP_BUNDLE_IDENTIFIER = dev.remodex.CodexMobile
REMODEX_TESTS_BUNDLE_IDENTIFIER = $(REMODEX_APP_BUNDLE_IDENTIFIER).tests
REMODEX_UI_TESTS_BUNDLE_IDENTIFIER = $(REMODEX_APP_BUNDLE_IDENTIFIER).uitests
REMODEX_APP_URL_NAME = $(REMODEX_APP_BUNDLE_IDENTIFIER).auth
REMODEX_BG_REFRESH_IDENTIFIER = $(REMODEX_APP_BUNDLE_IDENTIFIER).refresh

PHODEX_CHATGPT_CALLBACK_SCHEME = phodex
PHODEX_DEFAULT_RELAY_URL =

#include? "PrivateOverrides.xcconfig"
